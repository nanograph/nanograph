{
  "name": "nanograph-db",
  "version": "1.3.1",
  "description": "NanoGraph — embedded typed property graph DB for TypeScript/Node.js",
  "main": "index.js",
  "types": "types.d.ts",
  "napi": {
    "binaryName": "nanograph",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --js index.js --release",
    "build:debug": "napi build --platform --js index.js",
    "pretest": "npm run build",
    "test": "node --test __test__/index.spec.mjs"
  },
  "dependencies": {
    "@napi-rs/cli": "^3.0.0",
    "apache-arrow": "^21.0.0"
  },
  "optionalDependencies": {
    "nanograph-db-darwin-arm64": "1.3.1",
    "nanograph-db-darwin-x64": "1.3.1",
    "nanograph-db-linux-x64-gnu": "1.3.1",
    "nanograph-db-linux-arm64-gnu": "1.3.1",
    "nanograph-db-win32-x64-msvc": "1.3.1"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nanograph/nanograph"
  },
  "files": [
    "index.js",
    "types.d.ts",
    "src/",
    "build.rs",
    "Cargo.toml"
  ]
}
