// ── Decisions (4) ─────────────────────────────────────────────
{"type": "Decision", "data": {"slug": "dec-opaque-refresh", "summary": "Refresh tokens must be opaque, not JWT", "reasoning": "JWT refresh tokens cannot be revoked without a blocklist, which defeats the point of rotation. Opaque tokens keyed in Redis give us atomic single-use semantics: rotation deletes the old key, replay attempts fail with 401. Performance overhead of a Redis lookup per refresh is negligible versus the security benefit.", "decidedAt": "2026-04-08T14:00:00Z", "createdAt": "2026-04-08T14:00:00Z"}}
{"type": "Decision", "data": {"slug": "dec-redis-ratelimit", "summary": "Rate limiter must use Redis, not in-memory", "reasoning": "In-memory limits reset on every deploy and allow burst traffic above quota during rolling deploys. Customers noticed this during the March incident. Redis sliding window gives us consistent enforcement with sub-millisecond overhead. Cost: one Redis round-trip per API call. Acceptable.", "decidedAt": "2026-03-02T10:00:00Z", "createdAt": "2026-03-02T10:00:00Z"}}
{"type": "Decision", "data": {"slug": "dec-stripe-meter", "summary": "Use Stripe Meters API for usage tracking", "reasoning": "Rather than building our own usage ledger and reconciling with Stripe, the new Stripe Meters API lets Stripe be the source of truth. One less system to keep consistent. Requires Stripe API version 2024-06-20 or later.", "decidedAt": "2026-04-06T11:00:00Z", "createdAt": "2026-04-06T11:00:00Z"}}
{"type": "Decision", "data": {"slug": "dec-node22", "summary": "Node 22 LTS is the target for Q2", "reasoning": "Node 20 LTS ends active support in April 2026. Node 22 has measurable improvements in HTTP/2 perf and ESM resolution. We delayed upgrade during the refresh token work to avoid stacking changes.", "decidedAt": "2026-04-12T08:00:00Z", "createdAt": "2026-04-12T08:00:00Z"}}

