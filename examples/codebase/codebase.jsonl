// ── Epics (2) ─────────────────────────────────────────────────
{"type": "Issue", "data": {"slug": "ng-e001", "title": "Refresh token rotation", "description": "Move from long-lived access tokens to short-lived access + opaque refresh tokens with rotation. Invalidate old refresh tokens on use. Session migration required.", "status": "in_progress", "type": "epic", "priority": 1, "createdAt": "2026-04-01T09:00:00Z", "updatedAt": "2026-04-15T12:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-e002", "title": "Usage threshold alerts", "description": "Notify customers when their API usage approaches or exceeds their plan quota. Webhook + email delivery.", "status": "in_progress", "type": "epic", "priority": 2, "createdAt": "2026-04-05T10:00:00Z", "updatedAt": "2026-04-18T09:00:00Z"}}

// ── Issues under refresh-tokens epic (4) ──────────────────────
{"type": "Issue", "data": {"slug": "ng-rt01", "title": "Design token rotation scheme", "description": "Decide between sliding vs absolute refresh, token format (JWT vs opaque), revocation strategy, and Redis key layout. Write up the design doc.", "acceptance": "Design doc merged, reviewed by Sarah.", "status": "closed", "type": "task", "priority": 1, "claimedBy": "claude", "claimedAt": "2026-04-02T09:00:00Z", "closedAt": "2026-04-08T16:00:00Z", "closedReason": "Design approved. See DEC-opaque-refresh for the opaque-token decision.", "createdAt": "2026-04-01T09:05:00Z", "updatedAt": "2026-04-08T16:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-rt02", "title": "Implement /auth/refresh endpoint", "description": "Build the endpoint that exchanges a refresh token for a new access + refresh pair. Rotates the refresh token on each call. Stores state in Redis.", "acceptance": "Endpoint live behind feature flag, 100% unit test coverage on rotation logic, penetration-tested for replay attacks.", "design": "Opaque tokens keyed in Redis as hash. Old refresh marked invalid on rotation. 30-day absolute expiry.", "status": "in_progress", "type": "task", "priority": 1, "claimedBy": "claude", "claimedAt": "2026-04-10T10:00:00Z", "createdAt": "2026-04-01T09:10:00Z", "updatedAt": "2026-04-20T15:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-rt03", "title": "Migrate existing sessions to refresh tokens", "description": "Backfill Redis with refresh tokens for all active sessions at rollout. One-time migration script + verification.", "acceptance": "All active sessions have a valid refresh token. No user is forced to re-login.", "status": "open", "type": "task", "priority": 1, "createdAt": "2026-04-01T09:15:00Z", "updatedAt": "2026-04-01T09:15:00Z"}}
{"type": "Issue", "data": {"slug": "ng-rt04", "title": "Update TS and Swift SDKs for refresh tokens", "description": "Both SDKs need to handle the new refresh flow: automatic retry on 401 with refresh attempt, then fail. Expose refresh endpoint helpers.", "status": "open", "type": "task", "priority": 2, "createdAt": "2026-04-01T09:20:00Z", "updatedAt": "2026-04-01T09:20:00Z"}}

// ── Issues under usage-alerts epic (3) ────────────────────────
{"type": "Issue", "data": {"slug": "ng-ua01", "title": "Build usage meter", "description": "Track per-customer API call counts in 5-minute windows. Emit to Stripe Meters via the new API. Aggregate for dashboard.", "acceptance": "Meter records every authenticated API call. Visible in Stripe dashboard within 60s of the call.", "status": "in_progress", "type": "task", "priority": 2, "claimedBy": "devin", "claimedAt": "2026-04-12T11:00:00Z", "createdAt": "2026-04-05T10:05:00Z", "updatedAt": "2026-04-20T17:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-ua02", "title": "Define threshold rules", "description": "Config schema for per-plan thresholds: warn at 80%, block at 100%. Store in plans table. Evaluate against meter counts.", "status": "open", "type": "task", "priority": 2, "createdAt": "2026-04-05T10:10:00Z", "updatedAt": "2026-04-05T10:10:00Z"}}
{"type": "Issue", "data": {"slug": "ng-ua03", "title": "Webhook + email notifications", "description": "When a threshold rule fires, dispatch webhook (customer's configured URL) + email to billing contact. Retry with backoff on webhook failure.", "status": "open", "type": "task", "priority": 3, "createdAt": "2026-04-05T10:15:00Z", "updatedAt": "2026-04-05T10:15:00Z"}}

// ── Standalone issues (7) ─────────────────────────────────────
{"type": "Issue", "data": {"slug": "ng-bug01", "title": "JWT expiry incorrect in Safari", "description": "Safari users report being logged out after 5 minutes. Access token expiry is 1h but Safari does not persist the Date header correctly when Date.now() is spoofed by Lockdown Mode. Repro: Safari 17 + Lockdown Mode, any login.", "status": "open", "type": "bug", "priority": 1, "createdAt": "2026-04-18T14:00:00Z", "updatedAt": "2026-04-18T14:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-bug02", "title": "Customer double-charged on plan upgrade", "description": "User acme-corp was charged twice when upgrading from Pro to Enterprise on April 17. Stripe invoice 1842 and 1843 both for $4800. Needs refund + race fix.", "status": "open", "type": "bug", "priority": 0, "createdAt": "2026-04-19T08:00:00Z", "updatedAt": "2026-04-19T08:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-feat01", "title": "OAuth2 SSO with Google and Microsoft", "description": "Enterprise customers need SSO. Integrate with Google Workspace and Microsoft Entra. SCIM provisioning out of scope for v1.", "status": "open", "type": "feature", "priority": 2, "createdAt": "2026-04-10T11:00:00Z", "updatedAt": "2026-04-10T11:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-task01", "title": "Upgrade Node.js to 22 LTS", "description": "Currently on Node 20. Upgrade across all services. Verify that the Stripe SDK and Redis client still work.", "status": "open", "type": "task", "priority": 3, "createdAt": "2026-04-12T09:00:00Z", "updatedAt": "2026-04-12T09:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-task02", "title": "Add CI step for security scan", "description": "npm audit should run on every PR and block merge on high-severity findings. Currently only runs nightly.", "status": "open", "type": "task", "priority": 2, "createdAt": "2026-04-15T13:00:00Z", "updatedAt": "2026-04-15T13:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-bug03", "title": "Rate limiter allows burst above quota", "description": "The in-memory rate limiter resets on process restart. Deploy windows allow bursts of 10x quota. Known issue, see DEC-redis-ratelimit.", "status": "superseded", "type": "bug", "priority": 2, "closedAt": "2026-03-20T10:00:00Z", "closedReason": "Superseded by ng-task03 (Redis rate limiter migration).", "createdAt": "2026-02-01T10:00:00Z", "updatedAt": "2026-03-20T10:00:00Z"}}
{"type": "Issue", "data": {"slug": "ng-task03", "title": "Migrate rate limiter to Redis", "description": "Move from in-memory rate limiter to Redis-backed so limits survive process restarts. Use sliding window algorithm.", "status": "closed", "type": "task", "priority": 2, "claimedBy": "sarah", "claimedAt": "2026-03-05T10:00:00Z", "closedAt": "2026-03-25T16:00:00Z", "closedReason": "Deployed and validated. See DEC-redis-ratelimit.", "createdAt": "2026-03-01T10:00:00Z", "updatedAt": "2026-03-25T16:00:00Z"}}

