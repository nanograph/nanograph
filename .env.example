# Embedding provider: "openai" (default), "gemini", or "local"
# Auto-detected from available API keys or hf: model prefix if not set explicitly
# NANOGRAPH_EMBED_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=

# Gemini
# GEMINI_API_KEY=

# Model override (defaults: text-embedding-3-small for OpenAI, gemini-embedding-2-preview for Gemini)
NANOGRAPH_EMBED_MODEL=text-embedding-3-small
NANOGRAPH_EMBED_BATCH_SIZE=64
NANOGRAPH_EMBED_CACHE_MAX_ENTRIES=50000
NANOGRAPH_EMBED_CACHE_LOCK_STALE_SECS=60

# Enable load-time chunking for @embed source text (0 disables chunking)
NANOGRAPH_EMBED_CHUNK_CHARS=1500
NANOGRAPH_EMBED_CHUNK_OVERLAP_CHARS=200

# Local ONNX embeddings (requires building with --features local-embed):
# NANOGRAPH_EMBED_MODEL=hf:sentence-transformers/all-MiniLM-L6-v2
# The L12 variant is also supported (slower, same 384-d output):
# NANOGRAPH_EMBED_MODEL=hf:sentence-transformers/all-MiniLM-L12-v2
