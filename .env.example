# Embedding provider: "openai" (default), "gemini", or "lmstudio"
# Auto-detected from available API keys if not set explicitly
# NANOGRAPH_EMBED_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=

# Gemini
# GEMINI_API_KEY=

# LM Studio (local OpenAI-compatible server). No default model — set
# NANOGRAPH_EMBED_MODEL to whatever you have loaded in LM Studio. The
# loaded model dictates the output dimension; nanograph validates that
# it matches your schema's Vector(dim) and fails clearly if not.
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_API_KEY=     # optional, only if LM Studio is behind an auth proxy

# Model override (defaults: text-embedding-3-small for OpenAI, gemini-embedding-2-preview for Gemini, none for LM Studio)
NANOGRAPH_EMBED_MODEL=text-embedding-3-small
NANOGRAPH_EMBED_BATCH_SIZE=64
NANOGRAPH_EMBED_CACHE_MAX_ENTRIES=50000
NANOGRAPH_EMBED_CACHE_LOCK_STALE_SECS=60

# Enable load-time chunking for @embed source text (0 disables chunking)
NANOGRAPH_EMBED_CHUNK_CHARS=1500
NANOGRAPH_EMBED_CHUNK_OVERLAP_CHARS=200
